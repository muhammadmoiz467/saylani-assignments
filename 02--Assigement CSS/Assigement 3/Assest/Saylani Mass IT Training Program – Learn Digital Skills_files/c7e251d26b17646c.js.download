3,e=>{e.v(JSON.parse('{"breadcrumb":{"currentPage":"About Us","title":"About SMIT","description":"Empowering individuals through world-class IT education"},"section":{"eyebrow":"Our Foundation","heading":"Bridging the Digital Divide Through Education","paragraphs_html":["SMIT, an initiative of Saylani Welfare International Trust, is dedicated to providing <strong>high-quality, modern IT training</strong> to underprivileged and aspiring students across the globe. Our mission is simple: to equip the next generation with the coding and digital skills necessary to thrive in the 21st-century economy, irrespective of their financial background.","We believe access to top-tier technological education is a right, not a privilege. By focusing intensely on <strong>practical application and job readiness</strong>, we ensure our graduates are prepared to compete in the global marketplace."],"image":{"src":"/assets/student_hackethon.jpg","alt":"SMIT Quetta Campus","width":500,"height":400}}}'))},63848,e=>{"use strict";e.s(["default",()=>l]);var t=e.i(43476),a=e.i(57688),s=e.i(11782),i=e.i(89563);function l(){return(0,t.jsxs)(t.Fragment,{children:[(0,t.jsx)(s.default,{currentPage:i.default.breadcrumb.currentPage,title:i.default.breadcrumb.title,description:i.default.breadcrumb.description}),(0,t.jsxs)("section",{className:"min-h-screen bg-[#f8f8ff] flex flex-col md:flex-row items-center justify-center py-16 m-auto gap-12 max-w-6xl px-6 md:px-10",children:[(0,t.jsxs)("div",{className:"flex-1 max-w-xl",children:[(0,t.jsx)("h4",{className:"text-[#76B82A] text-sm font-semibold mb-2 uppercase",children:i.default.section.eyebrow}),(0,t.jsx)("h2",{className:"text-3xl md:text-4xl font-bold text-gray-900 leading-snug mb-4",children:i.default.section.heading}),(0,t.jsx)("p",{className:"text-gray-700 leading-relaxed mb-3",dangerouslySetInnerHTML:{__html:i.default.section.paragraphs_html}})]}),(0,t.jsx)("div",{className:"flex-1 flex justify-center",children:(0,t.jsx)("div",{className:"relati