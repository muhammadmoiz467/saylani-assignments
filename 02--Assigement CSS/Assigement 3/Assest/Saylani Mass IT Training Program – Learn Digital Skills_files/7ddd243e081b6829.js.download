_ahmed.png","videoUrl":"https://res.cloudinary.com/saylani-tech/video/upload/v1760107477/SMIT_8_iy5nsa.mp4"},{"id":7,"name":"Hamza Abdul Rehman","role":"Enterpreneur Student","thumbnail":"/assets/reviews/hamza_abdul_rehman.png","videoUrl":"https://res.cloudinary.com/saylani-tech/video/upload/v1760107478/SMIT_9_qgsowt.mp4"},{"id":8,"name":"Arham","role":"3D Design Animation Student","thumbnail":"/assets/reviews/arham.png","videoUrl":"https://res.cloudinary.com/saylani-tech/video/upload/v1760107479/SMIT_11_efzpv4.mp4"}]}'))},72520,e=>{"use strict";e.s(["ArrowRight",()=>t],72520);let t=(0,e.i(75254).default)("arrow-right",[["path",{d:"M5 12h14",key:"1ays0h"}],["path",{d:"m12 5 7 7-7 7",key:"xquz4c"}]])},73375,e=>{"use strict";e.s(["ChevronLeft",()=>t],73375);let t=(0,e.i(75254).default)("chevron-left",[["path",{d:"m15 18-6-6 6-6",key:"1wnfg3"}]])},83086,e=>{"use strict";e.s(["Sparkles",()=>t],83086);let t=(0,e.i(75254).default)("sparkles",[["path",{d:"M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z",key:"1s2grr"}],["path",{d:"M20 2v4",key:"1rf3ol"}],["path",{d:"M22 4h-4",key:"gwowj6"}],["circle",{cx:"4",cy:"20",r:"2",key:"6kqj1y"}]])},43432,e=>{"use strict";e.s(["Phone",()=>t],43432);let t=(0,e.i(75254).default)("phone",[["path",{d:"M13.832 16.568a1 1 0 0 0 1.213-.303l.355-.465A2 2 0 0 1 17 15h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2A18 18 0 0 1 2 4a2 2 0 0 1 2-2h3a2 2 0 0 1 2 2v3a2 2 0 0 1-.8 1.6l-.468.351a1 1 0 0 0-.292 1.233 14 14 0 0 0 6.392 6.384",key:"9njp5v"}]])},63059,e=>{"use strict";e.s(["ChevronRight",()=>t],63059);let t=(0,e.i(75254).default)("chevron-right",[["path",{d:"m9 18 6-6-6-6",key:"mthhwq"}]])},18566,(e,t,i)=>{t.exports=e.r(76562)},46897,e=>{"use strict";e.s(["MapPin",()=>t],46897);let t=(0,e.i(75254).default)("map-pin",[["path",{d:"M20 10c0 4.99